# Server
NODE_ENV=production
PORT=5000

# SQLite path (set to Railway volume mount in production)
DATABASE_PATH=/data/database.sqlite

# MySQL connection string (optional, takes precedence when set)
# Example: mysql://user:password@host:port/database
DATABASE_URL=

# Security
JWT_SECRET=replace-with-long-random-string
JWT_REFRESH_SECRET=replace-with-long-random-string
JWT_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Admin bootstrap
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password

# Frontend origin (Vercel URL)
FRONTEND_URL=https://app-mu-blush-91.vercel.app

# Optional additional origins (comma separated)
ADDITIONAL_ORIGINS=

# Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Optional email settings
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=JDExchange <no-reply@jdexchange.com>

# Optional external API
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
AUTH_RATE_LIMIT_MAX=100
